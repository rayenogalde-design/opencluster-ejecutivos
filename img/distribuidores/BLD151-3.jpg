<!DOCTYPE html>
<html>
<head>
  <title>Se produjo un error en el Servidor</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <style>
    body {
      background: #F4F4F4;
      color: #fff;
      text-align: center;
      font-family: arial, sans-serif;
      margin: 0;
      padding: 0;
    }

    header {
      background: #fff;
    }

    header figure {
      margin: 0;
      padding: 40px;
    }

    .gray-container {
      padding: 60px 0;
    }

    .gray-container .back-button {
      margin-top: 70px;
    }

    img.img-responsive {
      max-width: 100%;
    }
  </style>
</head>

<body>
  <!-- This file lives in public/404.html -->
  <header>
    <figure>
      <img src="/img/logo.png" alt="Blunding" width="200">
    </figure>
  </header>

  <div class='gray-container'>
    <figure>
      <img src='/img/500.png' class='img-responsive' alt='Imagen error 500' width="390">
    </figure>

    <figure class='back-button'>
      <a href='https://www.blunding.com'>
        <img src='/img/back.png' alt='Página no encontrada' width="70">
      </a>
    </figure>
  </div>
</body>
</html>
